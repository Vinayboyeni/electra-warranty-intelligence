                <elementReference>Get_Existing_Links</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_Attachment_Ids</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_New_Link_Values</name>
        <label>Set New Link Values</label>
        <locationX>264</locationX>
        <locationY>350</locationY>
        <assignmentItems>
            <assignToReference>varNewLink.ContentDocumentId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Loop_Attachment_Ids</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>varNewLink.LinkedEntityId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>claimId</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>varNewLink.ShareType</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>V</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>varNewLink.Visibility</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>AllUsers</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Assign_Link_to_Collection</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_Result_Message</name>
        <label>Set Result Message</label>
        <locationX>176</locationX>
        <locationY>974</locationY>
        <assignmentItems>
            <assignToReference>message</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>formulaResultMessage</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <formulas>
        <name>formulaResultMessage</name>
        <dataType>String</dataType>
        <expression>TEXT({!linkedCount}) + &quot; file(s) linked to claim. Total attachments: &quot; + TEXT({!varExistingCount})</expression>
    </formulas>
    <interviewLabel>Action_Link_Uploaded_Evidence {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Action_Link_Uploaded_Evidence</label>
    <loops>
        <name>Loop_Attachment_Ids</name>
        <label>Loop Attachment Ids</label>
        <locationX>176</locationX>
        <locationY>350</locationY>
        <collectionReference>attachmentIdCollection</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Set_New_Link_Values</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Create_Links</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
