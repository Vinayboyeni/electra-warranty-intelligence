system:
   instructions: |
       You are ARIA — the Authorized Repair Intelligence Assistant for Electra Cars.
       You interact with certified Dealership Service Advisors over WhatsApp.


       RULES:
       - Respond in English only.
       - Keep every response under 3 sentences. Be concise and mobile-friendly.
       - Ask for ONE piece of information per message. Never overwhelm the dealer.
       - Use *bold* for claim numbers, verdicts, and key values.
       - Never say a claim is submitted unless you have received a Claim Number from the Action_create_warranty_Claim action.
       - Never invent coverage rules, pricing, or technical specs.
       - If the dealer mentions fire, smoke, brake failure, or steering loss, immediately say: "SAFETY ALERT — Contact Electra Safety Hotline: 1-800-ELECTRA (24/7) immediately." and stop the claim workflow.
   messages:
       welcome: "Welcome to the Electra Cars Warranty Portal. I'm ARIA, your Authorized Repair Intelligence Assistant. To start a Prior Authorization request, please share the vehicle VIN."
       error: "A system error occurred. Your session data is saved. Reply RETRY to continue, or AGENT to reach a claim specialist."

config:
   agent_label: "ARIA WhatsApp Intake Agent"
   developer_name: "Warranty_Dealer_Intake_Agentt"
   agent_type: "AgentforceServiceAgent"
   description: "Guides Electra Cars dealership service advisors through warranty prior-authorization via WhatsApp."
   default_agent_user: "warranty_dealer_intake_agentt@00dbm00000fnzej1185441077.ext"

variables:
   vin: mutable string
       description: "Stores the 17-character Vehicle Identification Number provided by the dealer."
       visibility: "Internal"
   vehicle_id: mutable string
       description: "Stores the Salesforce Vehicle record ID from the VIN lookup."
       visibility: "Internal"
   vehicle_model: mutable string
       description: "Stores the vehicle model name returned by the VIN lookup."
       visibility: "Internal"
   vehicle_year: mutable number
       description: "Stores the vehicle model year returned by the VIN lookup."
       visibility: "Internal"
   customer_id: mutable string
       description: "Stores the Salesforce Customer Contact/Account ID."
       visibility: "Internal"
   dealer_id: mutable string
       description: "Stores the Salesforce Dealer Account ID."
       visibility: "Internal"
   odometer: mutable number
       description: "Stores the current odometer reading in miles provided by the dealer."
       visibility: "Internal"
   part_category: mutable string
       description: "Stores the part category selected by the dealer (e.g., Battery, Engine)."
       visibility: "Internal"
   symptom: mutable string
       description: "Stores the symptom or concern described by the dealer."
       visibility: "Internal"
   requested_amount: mutable number
       description: "Stores the estimated repair cost in USD provided by the dealer."
       visibility: "Internal"
   fault_date: mutable date
       description: "Stores the date the fault first occurred (YYYY-MM-DD)."
       visibility: "Internal"
   repair_order_number: mutable string
       description: "Stores the dealer's internal Repair Order number."
       visibility: "Internal"
   diagnostic_code_description: mutable string
       description: "Stores the decoded DTC description returned by DecodeDiagnosticCode."
       visibility: "Internal"
   srt_justification: mutable string
       description: "Stores the dealer's justification when repair amount exceeds the SRT baseline, or the goodwill/clarification reason."
       visibility: "Internal"
   coverage_eligibility: mutable string
       description: "Stores the coverage verdict: Likely, Borderline, or Not Covered."
       visibility: "Internal"
   coverage_rationale: mutable string
       description: "Stores the explanation of the coverage decision."
       visibility: "Internal"
   claim_id: mutable string
       description: "Stores the Salesforce ID of the created Claim record."
       visibility: "Internal"
   claim_number: mutable string
       description: "Stores the human-readable claim number (e.g., WC-00042)."
       visibility: "Internal"
   claim_status: mutable string
       description: "Stores the current status of the claim."
       visibility: "Internal"
   image_url: mutable string
       description: "Stores the URL of the damage photo retrieved from the WhatsApp session."
       visibility: "Internal"
   damage_analysis: mutable string
       description: "Stores the AI image analysis result from the damage photo."
       visibility: "Internal"
   slack_notified: mutable boolean
       description: "Stores whether the OEM approver was notified via Slack after claim creation."
       visibility: "Internal"
   srt_baseline_amount: mutable number
       description: "Stores the SRT standard baseline amount for the part category."
       visibility: "Internal"
   srt_is_within_range: mutable boolean
       description: "Stores whether the dealer's repair amount is within 20% of the SRT baseline."
       visibility: "Internal"
   duplicate_claim_found: mutable boolean
       description: "Stores whether a duplicate open claim exists for the same VIN and part."
       visibility: "Internal"
   duplicate_claim_number: mutable string
       description: "Stores the claim number of the duplicate, if found."
       visibility: "Internal"
   EndUserId: linked string
       source: @MessagingSession.MessagingEndUserId
       description: "This variable may also be referred to as MessagingEndUser Id"
   RoutableId: linked string
       source: @MessagingSession.Id
       description: "This variable may also be referred to as MessagingSession Id"
   ContactId: linked string
       source: @MessagingEndUser.ContactId
       description: "This variable may also be referred to as MessagingEndUser ContactId"
   user_confirmed: mutable boolean
       description: "Deterministic gate for claim submission. True only after the dealer explicitly confirms the claim summary (YES/yep/sure/confirm). Reset to False if any required field changes after confirmation."
       visibility: "Internal"
language:
   default_locale: "en_US"

knowledge:
   citations_enabled: False

start_agent agent_router:
   label: "Agent Router"
   description: "Routes dealer messages to the correct subagent based on intent."
   model_config:
       model: "model://sfdc_ai__DefaultEinsteinHyperClassifier"
   reasoning:
       instructions: ->
           | Objective: Triage the dealer's message, clarify missing details, and transition to the most relevant subagent.
           | 1) Identify goal and inputs: Briefly summarize the dealer's intent (e.g., start claim with VIN, check claim status, policy question, goodwill request, approver follow-up, escalation, off-topic). Required cues: VIN (17 chars), claim number (e.g., WC-00042), mention of prior auth/coverage, GOODWILL, responding to approver, AGENT/escalate, or clearly unrelated content.
           | 2) If critical inputs are missing, ask up to 2 targeted questions (e.g., "Do you have the 17-character VIN?", "What is the claim number?") before routing. Prefer existing subagents/actions; do not invent capabilities.
           | 3) Routing logic (deterministic preference):
           |    - If dealer replies RETRY after a system error in claim submission, transition to WarrantyIntake to retry with stored data.
           |    - If VIN provided, a specific issue is described, or user asks to start/submit a claim, transition to WarrantyIntake.
           |    - If asking about an existing claim or providing a claim number, transition to ClaimStatusInquiry.
           |    - If asking general warranty policy questions without a VIN, transition to WarrantyPolicyFAQ.
           |    - If vague warranty terms (e.g., "warranty", "coverage", "prior auth") without specifics, transition to WarrantyIntake (it will guide VIN collection).
           |    - If dealer explicitly replies GOODWILL or requests a policy exception after a Not Covered outcome, transition to GoodwillReview. A Borderline verdict alone is NOT a trigger for goodwill — only route to GoodwillReview when the dealer types GOODWILL explicitly.
           |    - If responding to an approver's request for more information, transition to ApproverFollowUp.
           |    - If dealer requests a human (AGENT) or indicates escalation, transition to Escalation.
           |    - If message is unrelated to warranties/vehicles/Electra Cars, transition to off_topic.
           | 4) For any risky/irreversible operation, only confirm intent here and defer execution to the destination subagent. Never compose a success message for claim creation without an action step executed in the same plan turn by the destination subagent.
           | 5) Transition explicitly using the single best-matching option below.
           | Guardrails: Do not fabricate data; rely on org data and available actions/subagents; hand off or escalate when out of scope.
       actions:
           go_to_WarrantyIntake: @utils.transition to @subagent.WarrantyIntake
           go_to_ClaimStatusInquiry: @utils.transition to @subagent.ClaimStatusInquiry
           go_to_WarrantyPolicyFAQ: @utils.transition to @subagent.WarrantyPolicyFAQ
           go_to_GoodwillReview: @utils.transition to @subagent.GoodwillReview
           go_to_ApproverFollowUp: @utils.transition to @subagent.ApproverFollowUp
           go_to_Escalation: @utils.transition to @subagent.Escalation
           go_to_off_topic: @utils.transition to @subagent.off_topic

subagent WarrantyIntake:
    label: "Warranty Intake"
    description: "Handles new warranty prior-authorization requests. Activated when a dealer provides a VIN, mentions a vehicle issue, wants to submit a claim, or asks about repair coverage for a specific vehicle."
    reasoning:
        instructions: ->
            | Objective: Collect claim details and submit a prior-authorization claim when the dealer confirms.
            | 1) Collect fields ONE AT A TIME. When the dealer provides a value, immediately persist it via its helper BEFORE any tool call: vin → {!@actions.set_variable_vin}; odometer → {!@actions.set_variable_odometer}; part_category → {!@actions.set_variable_part_category}; symptom → {!@actions.set_variable_symptom}; fault_date → {!@actions.set_variable_fault_date}; repair amount → {!@actions.set_variable_requested_amount}.
            | 2) Run tools as inputs become available: {!@actions.tool_FindVehicleByVin} (after vin) → confirm year/model; {!@actions.tool_CheckRecentClaims} (after part_category); {!@actions.tool_EvaluateCoverage} (after odometer+part_category); {!@actions.tool_DecodeDiagnosticCode} if a DTC is provided; {!@actions.tool_ValidateRepairEstimate} (after amount). Reflect results exactly as returned; do not invent data.
            | 3) Routing on intermediate results: if duplicate_claim_found is True, share the existing claim number and ask whether to continue or switch to ClaimStatusInquiry. If coverage_eligibility is exactly "Not Covered" (NOT "Borderline" and NOT "Likely"), offer {!@actions.go_to_GoodwillReview}. For "Borderline" or "Likely", proceed normally — a Borderline verdict is eligible for standard claim submission and must NEVER trigger a goodwill offer. If ValidateRepairEstimate.isWithinRange is False, ask the dealer to explain why the cost is above the SRT baseline; when they reply, IMMEDIATELY call {!@actions.set_variable_srt_justification} with their explanation text before continuing — the submission tool reads this variable.
            | 4) When all required fields are populated (vin, dealer_id, customer_id, odometer, part_category, symptom, requested_amount), summarize the claim (year/model, VIN, part, symptom, fault date, estimate, verdict) in one concise message and ask the dealer to confirm with YES.
            | 5) Submission (deterministic): On YES/yep/sure/confirm, FIRST call {!@actions.set_variable_user_confirmed} to set user_confirmed=True. IMMEDIATELY in the same turn, invoke {!@actions.tool_Action_Create_Warranty_Claim}. Do NOT emit any assistant text before the tool returns — the progress indicator handles UX.
            | 6) Post-submission: if claim_number is non-empty, reply exactly: "✅ Claim Submitted! Claim #: **{!@variables.claim_number}** | OEM Approver notified | SLA: 24 business hours. Send a photo of the {!@variables.part_category} to speed up review, or reply SKIP." If the dealer replies SKIP, say: "Your claim *{!@variables.claim_number}* is in review. Reply STATUS anytime." If the dealer sends a photo, call {!@actions.tool_GetWhatsAppMediaURL} then {!@actions.tool_AnalyzeImageDamage}. If the dealer says "new claim", "another one", "next claim", or provides a fresh VIN: IMMEDIATELY call {!@actions.set_variable_reset_after_submit} passing empty strings / False for every parameter to clear per-claim state, then restart from step 1 with the new VIN. If claim_number is empty/null, apologize and offer RETRY or AGENT. Never output a success message without a real claim_number.
            | 7) If the dealer changes any field after confirming, re-run the matching set_variable_* helper, call {!@actions.set_variable_user_confirmed} with False to reset, and ask for re-confirmation before resubmission.
            | Guardrails: Do not fabricate data; prefer org actions and stored variables; hand off to GoodwillReview or Escalation when out of scope.
        actions:
            set_variable_vin: @utils.setVariables
                description: "Store the 17-character VIN provided by the dealer into the vin variable. Call immediately when the dealer provides the VIN, BEFORE invoking tool_FindVehicleByVin."
                with vin = ...
            set_variable_odometer: @utils.setVariables
                description: "Parse and store the odometer reading (numeric, strip units) into the odometer variable. Call immediately when the dealer provides the odometer."
                with odometer = ...
            set_variable_part_category: @utils.setVariables
                description: "Store the part category (e.g., Battery, Engine, Drive Motor) into the part_category variable. Call immediately when the dealer identifies the part."
                with part_category = ...
            set_variable_symptom: @utils.setVariables
                description: "Store the dealer's described symptom into the symptom variable. Call immediately when the dealer describes the fault."
                with symptom = ...
            set_variable_fault_date: @utils.setVariables
                description: "Store the fault date (ISO format YYYY-MM-DD) into the fault_date variable. Call immediately when the dealer provides the fault date."
                with fault_date = ...
            set_variable_user_confirmed: @utils.setVariables
                description: "Set user_confirmed=True when the dealer replies YES/yep/sure/confirm to the final claim summary. Call this BEFORE tool_Action_Create_Warranty_Claim in the same turn. Also call with False to reset if the dealer modifies any required field after confirmation."
                with user_confirmed = ...
            tool_FindVehicleByVin: @actions.FindVehicleByVin
                available when @variables.vin is not None and @variables.vin != ""
                with vin = @variables.vin
                set @variables.vehicle_id = @outputs.vehicleId
                set @variables.vehicle_model = @outputs.vehicleModel
                set @variables.vehicle_year = @outputs.year
                set @variables.customer_id = @outputs.customerId
                set @variables.dealer_id = @outputs.dealerId
            tool_CheckRecentClaims: @actions.CheckRecentClaims
                available when @variables.vin is not None and @variables.vin != "" and @variables.part_category is not None
                with vin = @variables.vin
                with partCategory = @variables.part_category
                set @variables.duplicate_claim_found = @outputs.duplicateFound
                set @variables.duplicate_claim_number = @outputs.existingClaimNumber
            tool_EvaluateCoverage: @actions.EvaluateCoverage
                available when @variables.vehicle_id is not None and @variables.odometer is not None and @variables.part_category is not None
                with vehicleId = @variables.vehicle_id
                with odometer = @variables.odometer
                with partCategory = @variables.part_category
                set @variables.coverage_eligibility = @outputs.eligibility
                set @variables.coverage_rationale = @outputs.rationale
            tool_DecodeDiagnosticCode: @actions.DecodeDiagnosticCode
                with dtcCode = ...
                with vehicleId = @variables.vehicle_id
                set @variables.diagnostic_code_description = @outputs.dtcDescription
            set_variable_requested_amount: @utils.setVariables
                description: "Parse and store the dealer's numeric repair amount (e.g., '$1,250' or '1250.00') into the requested_amount variable. Call immediately when the dealer provides the repair estimate."
                with requested_amount = ...
            tool_ValidateRepairEstimate: @actions.ValidateRepairEstimate
                available when @variables.requested_amount is not None and @variables.part_category is not None
                with partCategory = @variables.part_category
                with requestedAmount = @variables.requested_amount
                set @variables.srt_baseline_amount = @outputs.baselineAmount
                set @variables.srt_is_within_range = @outputs.isWithinRange
            tool_Action_Create_Warranty_Claim: @actions.Action_Create_Warranty_Claim
                available when @variables.user_confirmed == True and @variables.vin is not None and @variables.vin != "" and @variables.dealer_id is not None and @variables.customer_id is not None and @variables.part_category is not None and @variables.requested_amount is not None and @variables.symptom is not None and @variables.odometer is not None
                with vin = @variables.vin
                with dealerId = @variables.dealer_id
                with customerId = @variables.customer_id
                with odometer = @variables.odometer
                with partCategory = @variables.part_category
                with requestedAmount = @variables.requested_amount
                with symptom = @variables.symptom
                with faultDate = @variables.fault_date
                with diagnosticCodeText = @variables.diagnostic_code_description
                with srtJustification = @variables.srt_justification
                with channel = "WhatsApp"
                with authorizationType = "Prior Authorization"
                set @variables.claim_id = @outputs.claimId
                set @variables.claim_number = @outputs.claimNumber
                set @variables.claim_status = @outputs.status
                set @variables.slack_notified = @outputs.slackNotificationSent
            tool_GetWhatsAppMediaURL: @actions.GetWhatsAppMediaURL
                with messagingUserId = @variables.EndUserId
                set @variables.image_url = @outputs.imageUrl
            tool_AnalyzeImageDamage: @actions.AnalyzeImageDamage
                with claimId = @variables.claim_id
                with imageUrl = @variables.image_url
                with partName = @variables.part_category
                set @variables.damage_analysis = @outputs.analysisResult
            set_variable_srt_justification: @utils.setVariables
                description: "Store the dealer's written justification when their repair estimate is >20% above the SRT baseline. Call IMMEDIATELY when the dealer explains why their cost is higher, BEFORE tool_Action_Create_Warranty_Claim. The submission tool reads this variable to attach the justification for approver review."
                with srt_justification = ...
            set_variable_reset_after_submit: @utils.setVariables
                description: "Clear all per-claim variables after a successful submission so the dealer can start a fresh claim in the same WhatsApp session. Call ONLY after claim_number is confirmed (Step 6 complete) and the dealer says 'new claim' or 'another one'. Pass empty values for every mutable claim field."
                with vin = ...
                with vehicle_id = ...
                with vehicle_model = ...
                with odometer = ...
                with part_category = ...
                with symptom = ...
                with fault_date = ...
                with repair_order_number = ...
                with requested_amount = ...
                with diagnostic_code_description = ...
                with srt_justification = ...
                with coverage_eligibility = ...
                with claim_id = ...
                with claim_number = ...
                with user_confirmed = ...
                with duplicate_claim_found = ...
                with duplicate_claim_number = ...
            go_to_GoodwillReview: @utils.transition to @subagent.GoodwillReview
            go_to_Escalation: @utils.transition to @subagent.Escalation


    actions:
        FindVehicleByVin:
            description: "Looks up a vehicle and its active warranty details by VIN. Call this first whenever a dealer provides a VIN."
            label: "Find Vehicle By VIN"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Looking up vehicle..."
            target: "apex://FindVehicleByVin"
            inputs:
                "vin": string
                    description: "17-character Vehicle Identification Number provided by the dealer."
                    label: "VIN"
                    is_required: True
                    is_user_input: True
            outputs:
                "vehicleFound": boolean
                    description: "Whether a matching Vehicle record exists."
                    label: "Vehicle Found"
                    is_displayable: True
                    filter_from_agent: False
                "activeWarrantyFound": boolean
                    description: "Whether an active AssetWarranty exists for this vehicle."
                    label: "Active Warranty Found"
                    is_displayable: True
                    filter_from_agent: False
                "vehicleId": object
                    description: "Salesforce Vehicle record ID."
                    label: "Vehicle ID"
                    is_displayable: False
                    filter_from_agent: True
                    complex_data_type_name: "lightning__recordIdType"
                "dealerId": object
                    description: "Salesforce Dealer Account ID."
                    label: "Dealer ID"
                    is_displayable: False
                    filter_from_agent: True
                    complex_data_type_name: "lightning__recordIdType"
                "customerId": object
                    description: "Salesforce Customer Contact/Account ID."
                    label: "Customer ID"
                    is_displayable: False
                    filter_from_agent: True
                    complex_data_type_name: "lightning__recordIdType"
                "vehicleModel": string
                    description: "Vehicle model name (e.g., Electra X5)."
                    label: "Vehicle Model"
                    is_displayable: True
                    filter_from_agent: False
                "year": object
                    description: "Model year of the vehicle."
                    label: "Year"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__integerType"
                "coverageEndDate": object
                    description: "Date the active warranty expires."
                    label: "Coverage End Date"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__dateType"
                "coverageCategories": string
                    description: "Comma-separated list of covered part categories."
                    label: "Coverage Categories"
                    is_displayable: True
                    filter_from_agent: False
                "message": string
                    description: "Human-readable status message from the action."
                    label: "Message"
                    is_displayable: True
                    filter_from_agent: False
        CheckRecentClaims:
            description: "Checks whether an open claim already exists for the same VIN and part category within the last 30 days. Call after part category is known to prevent duplicate submissions."
            label: "Check Recent Claims"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Checking for duplicate claims..."
            target: "apex://CheckRecentClaims"
            inputs:
                "vin": string
                    description: "17-character vehicle VIN from the VIN lookup step."
                    label: "VIN"
                    is_required: True
                    is_user_input: False
                "partCategory": string
                    description: "Part category selected by the dealer."
                    label: "Part Category"
                    is_required: True
                    is_user_input: False
            outputs:
                "duplicateFound": boolean
                    description: "True if an open claim for the same VIN and part exists within 30 days."
                    label: "Duplicate Found"
                    is_displayable: True
                    filter_from_agent: False
                "existingClaimNumber": string
                    description: "Claim number of the duplicate, if found."
                    label: "Existing Claim Number"
                    is_displayable: True
                    filter_from_agent: False
                "existingClaimStatus": string
                    description: "Current status of the duplicate claim."
                    label: "Existing Claim Status"
                    is_displayable: True
                    filter_from_agent: False
                "daysSinceSubmission": object
                    description: "Number of days since the duplicate claim was submitted."
                    label: "Days Since Submission"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__integerType"
        EvaluateCoverage:
            description: "Evaluates warranty coverage eligibility based on vehicle, odometer, and part category. Returns Likely, Borderline, or Not Covered. Call after odometer and part category are collected."
            label: "Evaluate Coverage"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Evaluating warranty coverage..."
            target: "apex://CoverageEngine"
            inputs:
                "vehicleId": object
                    description: "Salesforce Vehicle record ID from the VIN lookup."
                    label: "Vehicle ID"
                    is_required: True
                    is_user_input: False
                    complex_data_type_name: "lightning__recordIdType"
                "odometer": object
                    description: "Current odometer reading in miles provided by the dealer."
                    label: "Odometer"
                    is_required: True
                    is_user_input: False
                    complex_data_type_name: "lightning__integerType"
                "partCategory": string
                    description: "Part category being claimed."
                    label: "Part Category"
                    is_required: True
                    is_user_input: False
            outputs:
                "eligibility": string
                    description: "Coverage verdict: Likely, Borderline, or Not Covered."
                    label: "Eligibility"
                    is_displayable: True
                    filter_from_agent: False
                "rationale": string
                    description: "Explanation of the coverage decision including dates and mileage."
                    label: "Rationale"
                    is_displayable: True
                    filter_from_agent: False
                "coverageId": object
                    description: "Salesforce ID of the matching AssetWarranty record."
                    label: "Coverage ID"
                    is_displayable: False
                    filter_from_agent: True
                    complex_data_type_name: "lightning__recordIdType"
        DecodeDiagnosticCode:
            description: "Decodes an OBD-II or OEM fault code into a human-readable description and recommended action. Call when the dealer provides a DTC code."
            label: "Decode Diagnostic Code"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Decoding diagnostic code..."
            target: "apex://DecodeDiagnosticCode"
            inputs:
                "dtcCode": string
                    description: "OBD-II or OEM fault code provided by the dealer (e.g., P0456, P0A80)."
                    label: "DTC Code"
                    is_required: True
                    is_user_input: True
                "vehicleId": object
                    description: "Salesforce Vehicle record ID from the VIN lookup."
                    label: "Vehicle ID"
                    is_required: False
                    is_user_input: False
                    complex_data_type_name: "lightning__recordIdType"
            outputs:
                "dtcDescription": string
                    description: "OEM-verified description of what the fault code means."
                    label: "DTC Description"
                    is_displayable: True
                    filter_from_agent: False
                "recommendedAction": string
                    description: "OEM-recommended repair action for this DTC code."
                    label: "Recommended Action"
                    is_displayable: True
                    filter_from_agent: False
                "dtcSeverity": string
                    description: "Severity level: Critical, High, Medium, or Low."
                    label: "DTC Severity"
                    is_displayable: True
                    filter_from_agent: False
                "isKnownIssue": boolean
                    description: "Whether this DTC is associated with a known TSB or recall campaign."
                    label: "Is Known Issue"
                    is_displayable: True
                    filter_from_agent: False
        ValidateRepairEstimate:
            description: "Validates the dealer repair amount against the Electra Cars SRT matrix. Flags estimates more than 20% above baseline for dealer justification. Call after the dealer provides a repair amount."
            label: "Validate Repair Estimate"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Validating repair estimate..."
            target: "apex://ValidateRepairEstimate"
            inputs:
                "partCategory": string
                    description: "Part category being repaired."
                    label: "Part Category"
                    is_required: True
                    is_user_input: False
                "requestedAmount": number
                    description: "Dealer's estimated repair cost in USD."
                    label: "Requested Amount"
                    is_required: True
                    is_user_input: True
            outputs:
                "baselineAmount": number
                    description: "Electra Cars SRT standard rate for this part category."
                    label: "Baseline Amount"
                    is_displayable: True
                    filter_from_agent: False
                "isWithinRange": boolean
                    description: "True if the requested amount is within 20% of the SRT baseline."
                    label: "Is Within Range"
                    is_displayable: True
                    filter_from_agent: False
                "variancePercent": number
                    description: "Percentage difference between requested amount and SRT baseline."
                    label: "Variance Percent"
                    is_displayable: True
                    filter_from_agent: False
                "validationMessage": string
                    description: "Human-readable validation summary shown to the Dealer."
                    label: "Validation Message"
                    is_displayable: True
                    filter_from_agent: False
        GetWhatsAppMediaURL:
            description: "Retrieves the URL of the latest image uploaded by the dealer in this WhatsApp session. Call when the dealer sends a photo after claim creation."
            label: "Get WhatsApp Media URL"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Retrieving your photo..."
            target: "apex://GetWhatsAppMediaUrl"
            inputs:
                "messagingUserId": string
                    description: "WhatsApp Messaging End User ID for this conversation session."
                    label: "Messaging User ID"
                    is_required: False
                    is_user_input: False
            outputs:
                "imageUrl": string
                    description: "URL of the photo uploaded by the dealer in the current session."
                    label: "Image URL"
                    is_displayable: False
                    filter_from_agent: True
                "success": boolean
                    description: "Whether a photo was successfully found in the session."
                    label: "Success"
                    is_displayable: True
                    filter_from_agent: False
        AnalyzeImageDamage:
            description: "Invokes a Vision AI model to analyze a photo of the damaged part. Returns a structural integrity assessment. Call after retrieving the media URL from GetWhatsAppMediaURL."
            label: "Analyze Image Damage"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Analyzing damage photo with AI..."
            target: "apex://ImageDamageAnalyzer"
            inputs:
                "claimId": object
                    description: "Salesforce ID of the claim to attach the image analysis to."
                    label: "Claim ID"
                    is_required: True
                    is_user_input: False
                    complex_data_type_name: "lightning__recordIdType"
                "imageUrl": string
                    description: "URL of the damage photo from the GetWhatsAppMediaURL action."
                    label: "Image URL"
                    is_required: True
                    is_user_input: False
                "partName": string
                    description: "Name or category of the part being photographed."
                    label: "Part Name"
                    is_required: True
                    is_user_input: False
            outputs:
                "analysisResult": string
                    description: "AI narrative assessment of the photo including structural integrity findings."
                    label: "Analysis Result"
                    is_displayable: True
                    filter_from_agent: False
                "isDamaged": boolean
                    description: "Whether clear damage is detected in the photo."
                    label: "Is Damaged"
                    is_displayable: True
                    filter_from_agent: False
        Action_Create_Warranty_Claim:
            description: |
                Creates a new Warranty Claim record in Automotive Cloud and notifies the OEM approver via Slack. ONLY call this after the dealer has explicitly confirmed YES to the claim summary (user_confirmed must be True). This action runs with elevated permissions to create claims on behalf of the dealer.
            label: "Action_Create_Warranty_Claim"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Submitting your warranty claim..."
            source: "Action_Create_Warranty_Claim"
            target: "flow://Action_Create_Warranty_Claim"
                
            inputs:
                "authorizationType": string
                    description: |
                      Authorization type
                    label: "authorizationType"
                    is_required: False
                    is_user_input: False
                "channel": string
                    description: |
                      Submission channel — always pass WhatsApp.
                    label: "channel"
                    is_required: False
                    is_user_input: False
                "customerId": string
                    description: |
                      Salesforce Customer Contact/Account ID from the VIN lookup.
                    label: "customerId"
                    is_required: True
                    is_user_input: False
                "dealerId": string
                    description: |
                      Salesforce Dealer Account ID from the VIN lookup.
                    label: "dealerId"
                    is_required: True
                    is_user_input: False
                "dealerWhatsAppNumber": string
                    description: |
                      dealerWhatsAppNumber
                    label: "dealerWhatsAppNumber"
                    is_required: False
                    is_user_input: False
                "diagnosticCodeText": string
                    description: |
                      Decoded DTC description from the Decode Diagnostic Code action.
                    label: "diagnosticCodeText"
                    is_required: False
                    is_user_input: False
                "faultDate": date
                    description: |
                      Date the fault first occurred.
                    label: "faultDate"
                    is_required: False
                    is_user_input: False
                    complex_data_type_name: "lightning__dateType"
                "odometer": number
                    description: |
                      Current odometer reading in miles.
                    label: "odometer"
                    is_required: True
                    is_user_input: False
                    complex_data_type_name: "lightning__numberType"
                "partCategory": string
                    description: |
                      Part category being claimed.
                    label: "partCategory"
                    is_required: True
                    is_user_input: False
                "partId": string
                    description: |
                      partId
                    label: "partId"
                    is_required: False
                    is_user_input: False
                "requestedAmount": number
                    description: |
                      Repair cost estimate in USD.
                    label: "requestedAmount"
                    is_required: True
                    is_user_input: False
                    complex_data_type_name: "lightning__numberType"
                "srtJustification": string
                    description: |
                      srtJustification
                    label: "srtJustification"
                    is_required: False
                    is_user_input: False
                "symptom": string
                    description: |
                      Primary symptom description provided by the dealer.
                    label: "symptom"
                    is_required: True
                    is_user_input: False
                "vin": string
                    description: |
                      17-character Vehicle Identification Number.
                    label: "vin"
                    is_required: True
                    is_user_input: False
                
            outputs:
                "assetWarrantyId": string
                    description: |
                      assetWarrantyId
                    label: "assetWarrantyId"
                    is_displayable: False
                    filter_from_agent: False
                "claimId": string
                    description: |
                      Salesforce ID of the newly created Claim record.
                    label: "claimId"
                    is_displayable: False
                    filter_from_agent: True
                "claimItemId": string
                    description: |
                      ClaimitemId
                    label: "claimItemId"
                    is_displayable: False
                    filter_from_agent: False
                "claimNumber": string
                    description: |
                      Human-readable claim number shown to the dealer (e.g., WC-00042).
                    label: "claimNumber"
                    is_displayable: True
                    filter_from_agent: False
                "eligibility": string
                    description: |
                      eligibility
                    label: "eligibility"
                    is_displayable: False
                    filter_from_agent: False
                "rationale": string
                    description: |
                      rationale
                    label: "rationale"
                    is_displayable: False
                    filter_from_agent: False
                "slackNotificationSent": boolean
                    description: |
                      Whether the OEM approver was notified via Slack.
                    label: "slackNotificationSent"
                    is_displayable: True
                    filter_from_agent: False
                "status": string
                    description: |
                      Initial status of the created claim.
                    label: "status"
                    is_displayable: True
                    filter_from_agent: False
                "vehicleId_out": string
                    description: |
                      vehicleId_Out
                    label: "vehicleId_out"
                    is_displayable: False
                    filter_from_agent: False

subagent ClaimStatusInquiry:
   label: "Claim Status Inquiry"
   description: "Handles dealer requests to check the status of an existing claim. Activated when dealer asks about a claim status, mentions a claim number, or asks 'where is my claim'."
   reasoning:
       instructions: ->
           | Objective: Retrieve and present the current status of an existing claim.
           | 1) Identify goal and inputs: Need claim_number or VIN to search. Use {!@actions.GetClaimStatus}.
           | 2) If missing both, ask up to 2 concise questions to obtain the claim number or VIN; otherwise proceed.
           | 3) Invoke GetClaimStatus with the provided key(s); capture status, assigned approver, SLA due, next step, and any approver comment.
           | 4) Verify results and reflect back only what the action returns (claim number, status, approver, SLA due, next step, approver note if present). If not found, state no record found and request re-check.
           | 5) Risky/irreversible: None here; do not make changes to claims from this subagent.
           | 6) Completion: Provide an outcome-focused summary and offer next steps (REVIEW to start a new claim via intake, or AGENT to escalate).
           | Guardrails: Do not fabricate data; prefer org data and actions; hand off or escalate when out of scope.
       actions:
           GetClaimStatus: @actions.GetClaimStatus
               with claimNumber = ...
               with vin = ...
               set @variables.claim_number = @outputs.claimNumber
               set @variables.claim_status = @outputs.claimStatus
           go_to_WarrantyIntake: @utils.transition to @subagent.WarrantyIntake
           go_to_Escalation: @utils.transition to @subagent.Escalation

   actions:
      GetClaimStatus:
          description: "Retrieves current claim status, assigned approver, and SLA deadline for a submitted claim. Call when the dealer asks about an existing claim by claim number or VIN."
          label: "Get Claim Status"
          require_user_confirmation: False
          include_in_progress_indicator: True
          progress_indicator_message: "Looking up your claim..."
          target: "apex://GetClaimStatus"
          inputs:
              "claimNumber": string
                  description: "Claim number to look up (e.g., WC-00042)."
                  label: "Claim Number"
                  is_required: False
                  is_user_input: True
              "vin": string
                  description: "VIN as an alternative lookup key."
                  label: "VIN"
                  is_required: False
                  is_user_input: True
          outputs:
              "claimNumber": string
                  description: "Confirmed claim number."
                  label: "Claim Number"
                  is_displayable: True
                  filter_from_agent: False
              "claimStatus": string
                  description: "Current status of the claim."
                  label: "Claim Status"
                  is_displayable: True
                  filter_from_agent: False
              "assignedApprover": string
                  description: "Name of the OEM adjuster assigned to this claim."
                  label: "Assigned Approver"
                  is_displayable: True
                  filter_from_agent: False
              "slaDueDate": object
                  description: "SLA deadline for review."
                  label: "SLA Due Date"
                  is_displayable: True
                  filter_from_agent: False
                  complex_data_type_name: "lightning__dateTimeStringType"
              "approverComment": string
                  description: "Latest note or comment from the approver."
                  label: "Approver Comment"
                  is_displayable: True
                  filter_from_agent: False
              "nextStep": string
                  description: "Recommended next action for the dealer."
                  label: "Next Step"
                  is_displayable: True
                  filter_from_agent: False
              "claimFound": boolean
                  description: "Whether the claim was found."
                  label: "Claim Found"
                  is_displayable: False
                  filter_from_agent: True

subagent WarrantyPolicyFAQ:
   label: "Warranty Policy FAQ"
   description: "Answers dealer questions about Electra Cars warranty coverage rules, exclusions, mileage limits, or claim procedures — without a specific VIN or vehicle."
   reasoning:
       instructions: ->
           | Objective: Provide concise, policy-level answers and guide the dealer to next steps.
           | 1) Identify goal and inputs: Clarify the specific policy question. VIN is not required here.
           | 2) If the question is ambiguous, ask up to 2 targeted clarifiers; otherwise proceed.
           | 3) Select content to present from known policy guidelines (standard 4y/50k; powertrain 5y/60k; EV battery 8y/100k; covered categories; common exclusions; SLA 24 business hours; goodwill by manager approval). Do not add rules beyond those stated.
           | 4) Verify and reflect only policy facts; do not invent limits or criteria. If unsure, state limits of available information.
           | 5) Risky/irreversible: None; do not execute claim changes in this subagent.
           | 6) Completion: Offer next steps (start a claim via intake if a vehicle is involved; GOODWILL when applicable; AGENT for complex policy interpretation).
           | Guardrails: Do not fabricate data; prefer org data and actions; escalate when out of scope.
       actions:
           go_to_WarrantyIntake: @utils.transition to @subagent.WarrantyIntake
           go_to_Escalation: @utils.transition to @subagent.Escalation

subagent GoodwillReview:
   label: "Goodwill Review"
   description: "Handles requests for goodwill policy exceptions when standard warranty coverage is denied or borderline. Activated when dealer replies GOODWILL or requests a policy exception."
   reasoning:
       instructions: ->
           | Objective: Capture justification and submit a goodwill exception request for manager review.
           | 1) Identify goal and inputs: Need goodwill justification; if available, include claim_id; otherwise include vin, dealer_id, part_category. Use {!@actions.SubmitGoodwillReview}.
           | 2) If justification is missing, ask up to 2 concise prompts (e.g., loyal customer, safety-critical, just outside coverage).
           | 3) Invoke SubmitGoodwillReview with available identifiers and the collected reason.
           | 4) Verify results and reflect back claim number or message exactly as returned.
           | 5) Risky/irreversible: Submitting a goodwill request alters claim workflow; summarize intent and request explicit confirmation before calling the action when required by policy.
           | 6) Completion: Confirm submission and share review timeline; offer next steps (monitor status, AGENT for assistance).
           | Guardrails: Do not fabricate data; prefer org data and actions; escalate when out of scope.
       actions:
           SubmitGoodwillReview: @actions.SubmitGoodwillReview
               with claimId = @variables.claim_id
               with vin = @variables.vin
               with dealerId = @variables.dealer_id
               with partCategory = @variables.part_category
               with goodwillReason = ...
               set @variables.claim_number = @outputs.claimNumber
           go_to_Escalation: @utils.transition to @subagent.Escalation

   actions:
      SubmitGoodwillReview:
          description: "Flags a warranty claim for a goodwill policy exception review. Call after collecting the dealer's justification reason."
          label: "Submit Goodwill Review"
          require_user_confirmation: True
          include_in_progress_indicator: True
          progress_indicator_message: "Submitting goodwill request..."
          target: "apex://SubmitGoodwillReview"
          inputs:
              "claimId": object
                  description: "Existing Claim ID if a claim already exists from a previous intake."
                  label: "Claim ID"
                  is_required: False
                  is_user_input: False
                  complex_data_type_name: "lightning__recordIdType"
              "vin": string
                  description: "Vehicle VIN, used when no Claim ID exists to create a new goodwill claim."
                  label: "VIN"
                  is_required: False
                  is_user_input: False
              "dealerId": object
                  description: "Salesforce Dealer Account ID."
                  label: "Dealer ID"
                  is_required: False
                  is_user_input: False
                  complex_data_type_name: "lightning__recordIdType"
              "partCategory": string
                  description: "Part category involved in the goodwill request."
                  label: "Part Category"
                  is_required: False
                  is_user_input: False
              "goodwillReason": string
                  description: "Dealer's justification for the goodwill policy exception."
                  label: "Goodwill Reason"
                  is_required: True
                  is_user_input: True
          outputs:
              "status": string
                  description: "Operation result: Success or Error."
                  label: "Status"
                  is_displayable: True
                  filter_from_agent: False
              "claimNumber": string
                  description: "Claim number of the submitted goodwill request."
                  label: "Claim Number"
                  is_displayable: True
                  filter_from_agent: False
              "message": string
                  description: "Confirmation detail or error message."
                  label: "Message"
                  is_displayable: True
                  filter_from_agent: False

subagent ApproverFollowUp:
   label: "Approver Follow-Up"
   description: "Handles dealer replies to a 'Needs More Info' claim where the OEM approver has requested additional information or clarification."
   reasoning:
       instructions: ->
           | Objective: Capture the dealer's clarification and submit it back to the OEM approver.
           | 1) Identify goal and inputs: Need claim_number and dealer response text. Use {!@actions.SubmitClarificationResponse}.
           | 2) If claim number or response text is missing, ask up to 2 concise questions to gather them; otherwise proceed.
           | 3) Invoke SubmitClarificationResponse with claim_number and the dealer's response.
           | 4) Verify results and reflect back confirmation or error message exactly as returned.
           | 5) Risky/irreversible: None; this adds information but does not change claim decisions.
           | 6) Completion: Confirm the claim is back in review and provide expected SLA; offer AGENT for further assistance.
           | Guardrails: Do not fabricate data; prefer org data and actions; escalate when out of scope.
       actions:
           SubmitClarificationResponse: @actions.SubmitClarificationResponse
               with claimNumber = @variables.claim_number
               with dealerResponse = ...
           go_to_Escalation: @utils.transition to @subagent.Escalation

   actions:
      SubmitClarificationResponse:
          description: "Records the dealer's written response to an OEM clarification request and moves the claim back to Pending Approver Review."
          label: "Submit Clarification Response"
          require_user_confirmation: False
          include_in_progress_indicator: True
          progress_indicator_message: "Sending your response to the OEM approver..."
          target: "apex://SubmitDealerClarificationResponse"
          inputs:
              "claimNumber": string
                  description: "Claim number the dealer is responding to (e.g., WC-00042)."
                  label: "Claim Number"
                  is_required: True
                  is_user_input: False
              "dealerResponse": string
                  description: "The dealer's full written answer to the approver's clarification question."
                  label: "Dealer Response"
                  is_required: True
                  is_user_input: True
          outputs:
              "submitted": boolean
                  description: "True if the response was successfully recorded and the claim moved back to Pending Approver Review."
                  label: "Submitted"
                  is_displayable: True
                  filter_from_agent: False
              "message": string
                  description: "Confirmation or error message."
                  label: "Message"
                  is_displayable: True
                  filter_from_agent: False

subagent Escalation:
   label: "Escalation"
   description: "Escalates the conversation to a human OEM Service Adjuster. Activated when dealer says AGENT, requests a human, or expresses significant frustration."
   reasoning:
       instructions: ->
           | Objective: Transfer the conversation to a human adjuster with relevant context.
           | 1) Identify goal and inputs: Confirm the user wants a human handoff.
           | 2) If unclear, ask one brief confirmation question; otherwise proceed.
           | 3) Select and invoke escalation using the action below.
           | 4) Verify the handoff has been initiated; acknowledge transfer succinctly.
           | 5) Risky/irreversible: None; this is a handoff.
           | 6) Completion: Confirm that session context (VIN, symptoms, coverage, claim details if any) will accompany the transfer.
           | Guardrails: Do not fabricate data; prefer org data and actions; escalate when out of scope.
       actions:
           escalate_to_human: @utils.escalate
               description: "Call this tool if the dealer indicates that they wish to escalate to a human agent."

subagent off_topic:
   label: "Off Topic"
   description: "Redirect conversation to warranty-related topics when the dealer's request is unrelated to vehicle warranty claims or Electra Cars services."
   reasoning:
       instructions: ->
           | Objective: Politely redirect to warranty support and gather a minimal starting detail.
           | 1) Identify goal and inputs: Determine if this is a greeting or unrelated question.
           | 2) If unclear, ask up to 2 brief clarifiers; otherwise proceed.
           | 3) Provide a short redirect message: for greetings, offer help and request the VIN; for unrelated topics, state scope and ask what vehicle or warranty question they have.
           | 4) Verify user understanding; do not invent policy or technical data.
           | 5) Risky/irreversible: None; this subagent only redirects.
           | 6) Completion: Offer next steps (share VIN to start a claim, or AGENT for a specialist).
           | Guardrails: Do not fabricate data; prefer org data and actions; escalate when out of scope.
