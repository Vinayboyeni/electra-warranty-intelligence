        <locationX>176</locationX>
        <locationY>866</locationY>
        <connector>
            <targetReference>Set_Result_Message</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>claimId</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>AttachmentCount__c</field>
            <value>
                <elementReference>varExistingCount</elementReference>
            </value>
        </inputAssignments>
        <object>Claim</object>
    </recordUpdates>
    <start>
